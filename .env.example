# ── Application ─────────────────────────────────
APP_NAME=AI Support Agent Backend
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# ── API ─────────────────────────────────────────
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8603","http://127.0.0.1:8603","http://localhost:8605","http://127.0.0.1:8605","http://localhost:8610","http://127.0.0.1:8610"]

# ── Database ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support_db
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN_BLACKLIST_DB=1

# ── JWT ─────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Celery ──────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ── Gmail OAuth2 ────────────────────────────────
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI=http://localhost:8600/api/v1/gmail/callback
GMAIL_POLL_INTERVAL_SECONDS=60

# ── Logging ─────────────────────────────────────
LOG_LEVEL=INFO

# ── RAG Embeddings ───────────────────────────────
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
USE_GEMINI_EMBEDDINGS=False
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSION=384
GEMINI_EMBEDDING_QUERY_TASK_TYPE=RETRIEVAL_QUERY
GEMINI_EMBEDDING_DOCUMENT_TASK_TYPE=RETRIEVAL_DOCUMENT

# ── AI Response Providers ───────────────────────
# OPENAI_API_KEY is also used for Voice Agent STT (Whisper).
# google.STT requires a Google Cloud service account — NOT just a Gemini key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# (Supports comma-separated keys for auto-rotation / limits extension: key1,key2)
GEMINI_API_KEY=
AI_RESPONSE_PROVIDER=gemini               # openai | claude | gemini | local

# ── Local LLM (Ollama / llama.cpp / vLLM / LM Studio) ──
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODELS=llama3.2,mistral,gemma2,phi3,qwen2.5

# ── WhatsApp ────────────────────────────────────
# Provider: "bridge" (free whatsapp-web.js) or "meta" (official Cloud API)
WHATSAPP_PROVIDER=bridge

# Meta Cloud API (not needed for bridge mode, fill later for production)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=my-whatsapp-verify-token
WHATSAPP_API_VERSION=v21.0

# Web bridge settings
WHATSAPP_BRIDGE_URL=http://whatsapp_bridge:8602
WHATSAPP_BRIDGE_API_KEY=

# ── Voice Agents (LiveKit) ──────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880
# When running voice agents INSIDE Docker, use: ws://livekit:7880
# Note: Support for multiple Gemini API keys has been implemented.
# Pipeline mode (STT+LLM+TTS) is the default — reliable on free tier.
# Set to "true" to use Gemini Realtime API (single model, lower latency).
# WARNING: Realtime API requires a paid Gemini plan. Free-tier keys get error 1008.
USE_REALTIME=true
# ── Internal Service-to-Service Auth ────────────────────
# Shared key for voice agents → backend API communication (RAG access)
INTERNAL_SERVICE_KEY=change-me-internal-key

# ── Voice Agents Backend Integration ────────────────────
# URL of the backend API (for RAG knowledge base access)
BACKEND_API_URL=http://localhost:8600

# ── Voice Call Recording & Transcripts ──────────────────
VOICE_RECORDINGS_DIR=recordings

# ── Visual AI ────────────────────────────────────
VISUAL_AI_PROVIDER=google             # local-basic | local-advanced | google
VISUAL_CLIP_MODEL=clip-ViT-B-32              # Only used for local-basic provider. Advanced uses its own internal model. Ignored for google provider.
SCREENSHOT_DIR=screenshots                   # Directory to store uploaded screenshots for local processing. Ensure this is mounted as a volume if running in Docker.
MAX_SCREENSHOT_SIZE_MB=10                    # Max file size for uploaded screenshots. Adjust as needed, but keep in mind larger files will consume more memory and may increase processing time.
GAP_THRESHOLD_MINOR=0.15                     # Minimum confidence gap between current and next best object detection to be considered valid. Adjust based on testing to balance false positives vs missed detections.
GAP_THRESHOLD_SIGNIFICANT=0.40               # Higher confidence gap threshold for flagging detections as significant. Can be used to trigger more prominent alerts or actions in the UI.
GAP_THRESHOLD_CRITICAL=0.70                  # Very high confidence gap threshold for critical detections. Use with caution, as setting too high may result in missed important detections.
VISUAL_GUIDANCE_USE_LLM=false               # Set to true to use LLM for generating visual guidance based on screenshot analysis. Can reduce false positives but adds latency and cost.
GOOGLE_CLOUD_PROJECT=                       # Required if VISUAL_AI_PROVIDER=google and using a service account JSON with project_id field. Otherwise, can be left blank if GOOGLE_API_KEY has necessary permissions.

# ── Visual AI Screenshare ───────────────────────
VISUAL_SCREENSHARE_USE_GEMINI_EMBEDDINGS=False
VISUAL_SCREENSHARE_GEMINI_MODEL=gemini-embedding-2-preview
VISUAL_SCREENSHARE_EMBEDDING_DIMENSION=512
VISUAL_SCREENSHARE_TARGET_FPS=1.0
VISUAL_SCREENSHARE_MAX_FRAMES=120
VISUAL_SCREENSHARE_MAX_VIDEO_MB=50
VISUAL_SCREENSHARE_MAX_VIDEO_DURATION_SECONDS=300
VISUAL_SCREENSHARE_FFMPEG_BIN=ffmpeg
VISUAL_SCREENSHARE_FFPROBE_BIN=ffprobe
